{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/ai-career-scout/**",
        "destination": "https://ai-career-scout-ym.web.app"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}